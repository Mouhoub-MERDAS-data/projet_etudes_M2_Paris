data/*.csv
data/*.txt
data/*.json
data/*.xlsx
data/*.parquet
data/proceessed/*.csv
data/proceessed/*.parquet
data/proceessed/*.db
data/proceessed/*.png

# Garder la structure de dossiers (les .gitkeep restent versionnés)
!data/.gitkeep
!data/proceessed/.gitkeep
!**/.gitkeep

